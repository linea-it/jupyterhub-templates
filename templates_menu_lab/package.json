{
  "name": "templates-menu-lab",
  "version": "0.1.0",
  "description": "Templates menu in JupyterLab top bar (no jupyterlab_templates).",
  "keywords": ["jupyter", "jupyterlab", "jupyterlab-extension", "templates"],
  "files": [
    "lib/**/*.{d.ts,js}",
    "style/**/*.{css,js}",
    "schema/*.json"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension",
    "build:lib": "tsc",
    "build:labextension": "jupyter labextension build .",
    "clean": "rimraf lib tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/mainmenu": "^4.0.0",
    "@jupyterlab/translation": "^4.0.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "typescript": "~5.0.0",
    "rimraf": "^5.0.0"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "./labextension",
    "schemaDir": "schema"
  }
}
